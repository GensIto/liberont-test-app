{
  "name": "vite-react-template",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "version": "0.0.0",
  "dependencies": {
    "@hono/node-server": "^1.15.0",
    "@hono/zod-validator": "0.7.0",
    "@radix-ui/react-slot": "1.2.3",
    "@tailwindcss/vite": "4.1.11",
    "@tanstack/react-router": "1.125.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.1.0",
    "drizzle-orm": "0.44.2",
    "hono": "4.8.2",
    "lucide-react": "0.525.0",
    "mysql2": "3.14.1",
    "next-themes": "0.4.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sonner": "2.0.6",
    "tailwind-merge": "3.3.1",
    "tailwindcss": "4.1.11",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@hono/vite-dev-server": "^0.20.0",
    "@tanstack/router-plugin": "1.125.6",
    "@types/node": "24.0.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.6.0",
    "drizzle-kit": "0.31.4",
    "drizzle-seed": "0.3.1",
    "eslint": "9.27.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.2.0",
    "tsx": "4.20.3",
    "tw-animate-css": "1.3.5",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.0",
    "vite": "7.0.0",
    "wrangler": "4.24.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "dev:front": "vite",
    "dev:back": "tsx watch ./src/worker/index.ts",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx ./src/db/seed.ts",
    "up": "docker compose up",
    "down": "docker compose down"
  },
  "type": "module"
}
