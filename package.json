{
  "name": "vite-react-template",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "version": "0.0.0",
  "cloudflare": {
    "label": "Vite React Template",
    "products": [
      "Workers"
    ],
    "categories": [],
    "icon_urls": [
      "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/5ca0ca32-e897-4699-d4c1-6b680512f000/public"
    ],
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/fc7b4b62-442b-4769-641b-ad4422d74300/public",
    "publish": true
  },
  "dependencies": {
    "@hono/zod-validator": "0.7.0",
    "@tanstack/react-router": "1.125.6",
    "dotenv": "17.1.0",
    "drizzle-orm": "0.44.2",
    "hono": "4.8.2",
    "mysql2": "3.14.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.7.5",
    "@eslint/js": "9.29.0",
    "@pandacss/dev": "0.54.0",
    "@tanstack/router-plugin": "1.125.6",
    "@types/node": "24.0.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.6.0",
    "drizzle-kit": "0.31.4",
    "drizzle-seed": "0.3.1",
    "eslint": "9.27.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.2.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.0",
    "vite": "7.0.0",
    "wrangler": "4.24.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "prepare": "panda codegen",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "up": "docker compose up",
    "down": "docker compose down",
    "seed": "tsx ./src/db/seed.ts"
  },
  "type": "module"
}
